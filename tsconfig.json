{
  "include": ["src"],
  "compilerOptions": {
    "experimentalDecorators": true,
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "lib": [
      "dom",
      "es5",
      "es2015",
      "es2016",
      "es2017"
    ],
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "node",
    "noEmitOnError": false
  }
}
